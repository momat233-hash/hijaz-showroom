{
  "name": "hijaz-showroom",
  "version": "1.0.0",
  "description": "A showroom application for health equipment and plumbing tools with desktop support.",
  "main": "public/electron.js",
  "homepage": "./",
  "scripts": {
    "start": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts start",
    "build": "cross-env NODE_OPTIONS=--openssl-legacy-provider react-scripts build",
    "build-electron": "tsc --outDir dist/electron src/electron/main.ts && tsc --outDir dist/electron src/electron/preload.ts",
    "electron": "electron .",
    "electron-dev": "concurrently \"npm start\" \"wait-on http://localhost:3000 && npm run build-electron && electron .\"",
    "electron-build": "npm run build && npm run build-electron && electron-builder",
    "test": "react-scripts test",
    "eject": "react-scripts eject"
  },
  "dependencies": {
    "axios": "^0.21.1",
    "react": "^17.0.2",
    "react-dom": "^17.0.2",
    "react-router-dom": "^5.2.0",
    "react-scripts": "4.0.3"
  },
  "devDependencies": {
    "@types/node": "^16.11.0",
    "@types/react": "^17.0.0",
    "@types/react-dom": "^17.0.0",
    "basic-ftp": "^6.0.1",
    "concurrently": "^7.0.0",
    "cross-env": "^10.1.0",
    "electron": "^28.0.0",
    "electron-builder": "^24.9.0",
    "serve": "^14.2.6",
    "typescript": "^4.1.2",
    "wait-on": "^7.0.0"
  },
  "build": {
    "appId": "com.hijazshowroom.app",
    "productName": "Hijaz Showroom",
    "files": [
      "build/**/*",
      "public/electron.js",
      "dist/electron/**/*",
      "node_modules/**/*"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Hijaz Showroom"
    }
  },
  "keywords": [
    "health",
    "equipment",
    "plumbing",
    "sales",
    "orders",
    "payment"
  ],
  "author": "Hijaz Team",
  "license": "MIT",
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  }
}
